<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field name="search" type="text" description="COM_ACCOMMODATION_MANAGER_SEARCH_FILTER_SUBMIT"
               label="COM_USERS_FILTER_SEARCH_DESC"
               class="js-stools-search-string" />

        <field name="state"
               type="status"
               label="COM_ACCOMMODATION_MANAGER_FILTER_STATE"
               description="COM_ACCOMMODATION_MANAGER_FILTER_STATE_DESC"
               onchange="this.form.submit();"
        >
            <option value="">JOPTION_SELECT_PUBLISHED</option>
        </field>

        <field name="room_category"
               type="sql"
               label="COM_ACCOMMODATION_MANAGER_FILTER_CATEGORY"
               onchange="this.form.submit();"
               sql_select="id, room_category_title"
               sql_from="#__accommodation_manager_room_categories"
               sql_filter="state"
               sql_default_state="1"
               key_field="id"
               value_field="room_category_title"
        >
            <option value="">COM_ACCOMMODATION_MANAGER_FILTER_SELECT_CATEGORY</option>
        </field>



    </fields>

    <fields name="list">

        <field name="fullordering"
               type="list"
               label="COM_ACCOMMODATION_MANAGER_LIST_FULL_ORDERING"
               description="COM_ACCOMMODATION_MANAGER_LIST_FULL_ORDERING_DESC"
               onchange="this.form.submit();"
               default="a.id DESC"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.id ASC">COM_ACCOMMODATION_MANAGER_ID_ASC</option><option value="a.id DESC">COM_ACCOMMODATION_MANAGER_ID_DESC</option><option value="a.ordering ASC">COM_ACCOMMODATION_MANAGER_ORDERING_ASC</option><option value="a.ordering DESC">COM_ACCOMMODATION_MANAGER_ORDERING_DESC</option><option value="a.state ASC">COM_ACCOMMODATION_MANAGER_STATE_ASC</option><option value="a.state DESC">COM_ACCOMMODATION_MANAGER_STATE_DESC</option><option value="a.room_name ASC">COM_ACCOMMODATION_MANAGER_ROOM_NAME_ASC</option><option value="a.room_name DESC">COM_ACCOMMODATION_MANAGER_ROOM_NAME_DESC</option><option value="a.room_category ASC">COM_ACCOMMODATION_MANAGER_ROOM_CATEGORY_ASC</option><option value="a.room_category DESC">COM_ACCOMMODATION_MANAGER_ROOM_CATEGORY_DESC</option><option value="a.room_code ASC">COM_ACCOMMODATION_MANAGER_ROOM_CODE_ASC</option><option value="a.room_code DESC">COM_ACCOMMODATION_MANAGER_ROOM_CODE_DESC</option>

        </field>

       <field name="limit"
               type="limitbox"
               label="COM_ACCOMMODATION_MANAGER_LIST_LIMIT"
               description="COM_ACCOMMODATION_MANAGER_LIST_LIMIT_DESC"
               class="input-mini"
               default="25"
               onchange="this.form.submit();"
        />

    </fields>

</form>