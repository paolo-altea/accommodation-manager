<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Accomodationmanager\Component\Accommodation_manager\Administrator\Field">
  <fieldset>
    <field name="id" type="text" readonly="true" class="readonly" default="0" description="JGLOBAL_FIELD_ID_DESC"/>
    <field name="ordering"/>
    <field name="state" default="1" type="list" label="JSTATUS" description="JFIELD_PUBLISHED_DESC" class="inputbox" size="1">
      <option value="1">JPUBLISHED</option>
      <option value="0">JUNPUBLISHED</option>
      <option value="2">JARCHIVED</option>
      <option value="-2">JTRASHED</option>
    </field>
    <field name="checked_out" type="hidden" filter="unset"/>
    <field name="checked_out_time" default="0000-00-00 00:00:00" type="hidden" filter="unset"/>
    <field name="created_by" type="createdby" default="0" label="JGLOBAL_FIELD_CREATED_BY_LABEL" description="JGLOBAL_FIELD_CREATED_BY_DESC" hidden="true" hint="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATEPERIOD_CREATED_BY"/>
    <field name="period_start" class="inputbox" format="%Y-%m-%d" translateformat="false" showtime="false" singleheader="false" todaybutton="false" weeknumbers="false" filltable="false" type="calendar" required="true" label="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATEPERIOD_PERIOD_START" description="COM_ACCOMMODATION_MANAGER_FORM_DESC_MANAGERRATEPERIOD_PERIOD_START" hint="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATEPERIOD_PERIOD_START"/>
    <field name="period_end" class="inputbox" format="%Y-%m-%d" translateformat="false" showtime="false" singleheader="false" todaybutton="false" weeknumbers="false" filltable="false" type="calendar" required="true" label="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATEPERIOD_PERIOD_END" description="COM_ACCOMMODATION_MANAGER_FORM_DESC_MANAGERRATEPERIOD_PERIOD_END" hint="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATEPERIOD_PERIOD_END"/>
    <field name="period_title_de" filter="string" type="text" label="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATEPERIOD_PERIOD_TITLE_DE" description="COM_ACCOMMODATION_MANAGER_FORM_DESC_MANAGERRATEPERIOD_PERIOD_TITLE_DE" hint="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATEPERIOD_PERIOD_TITLE_DE"/>
    <field name="period_title_it" filter="string" type="text" label="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATEPERIOD_PERIOD_TITLE_IT" description="COM_ACCOMMODATION_MANAGER_FORM_DESC_MANAGERRATEPERIOD_PERIOD_TITLE_IT" hint="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATEPERIOD_PERIOD_TITLE_IT"/>
    <field name="period_title_en" filter="string" type="text" label="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATEPERIOD_PERIOD_TITLE_EN" description="COM_ACCOMMODATION_MANAGER_FORM_DESC_MANAGERRATEPERIOD_PERIOD_TITLE_EN" hint="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATEPERIOD_PERIOD_TITLE_EN"/>
    <field name="period_title_fr" filter="string" type="text" label="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATEPERIOD_PERIOD_TITLE_FR" description="COM_ACCOMMODATION_MANAGER_FORM_DESC_MANAGERRATEPERIOD_PERIOD_TITLE_FR" hint="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATEPERIOD_PERIOD_TITLE_FR"/>
    <field name="period_title_es" filter="string" type="text" label="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATEPERIOD_PERIOD_TITLE_ES" description="COM_ACCOMMODATION_MANAGER_FORM_DESC_MANAGERRATEPERIOD_PERIOD_TITLE_ES" hint="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATEPERIOD_PERIOD_TITLE_ES"/>
    <field name="version_note" type="text" label="JGLOBAL_FIELD_VERSION_NOTE_LABEL" description="JGLOBAL_FIELD_VERSION_NOTE_DESC" class="inputbox" size="45" labelclass="control-label"/>
  </fieldset>
</form>
