<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Accomodationmanager\Component\Accommodation_manager\Administrator\Field">
  <fieldset>
    <field name="id" type="text" readonly="true" class="readonly" default="0" description="JGLOBAL_FIELD_ID_DESC"/>
    <field name="ordering"/>
    <field name="state" default="1" type="list" label="JSTATUS" description="JFIELD_PUBLISHED_DESC" class="inputbox" size="1">
      <option value="1">JPUBLISHED</option>
      <option value="0">JUNPUBLISHED</option>
      <option value="2">JARCHIVED</option>
      <option value="-2">JTRASHED</option>
    </field>
    <field name="checked_out" type="hidden" filter="unset"/>
    <field name="checked_out_time" default="0000-00-00 00:00:00" type="hidden" filter="unset"/>
    <field name="created_by" type="createdby" default="0" label="JGLOBAL_FIELD_CREATED_BY_LABEL" description="JGLOBAL_FIELD_CREATED_BY_DESC" hidden="true" hint="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATE_CREATED_BY"/>
    <field name="room_id" type="foreignkey" label="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATE_ROOM_ID" description="COM_ACCOMMODATION_MANAGER_FORM_DESC_MANAGERRATE_ROOM_ID" default="" input_type="list" table="#__accommodation_manager_rooms" key_field="id" translate="true" value_field="id" required="true"/>
    <field name="period_id" type="foreignkey" label="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATE_PERIOD_ID" description="COM_ACCOMMODATION_MANAGER_FORM_DESC_MANAGERRATE_PERIOD_ID" default="" input_type="list" table="#__accommodation_manager_rate_periods" key_field="id" translate="true" value_field="id" required="true"/>
    <field name="typology_id" type="foreignkey" label="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATE_TYPOLOGY_ID" description="COM_ACCOMMODATION_MANAGER_FORM_DESC_MANAGERRATE_TYPOLOGY_ID" default="" input_type="list" table="#__accommodation_manager_rate_typologies" key_field="id" translate="true" value_field="id" required="true"/>
    <field name="rate" type="text" required="true" label="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATE_RATE" description="COM_ACCOMMODATION_MANAGER_FORM_DESC_MANAGERRATE_RATE" hint="COM_ACCOMMODATION_MANAGER_FORM_LBL_MANAGERRATE_RATE"/>
    <field name="version_note" type="text" label="JGLOBAL_FIELD_VERSION_NOTE_LABEL" description="JGLOBAL_FIELD_VERSION_NOTE_DESC" class="inputbox" size="45" labelclass="control-label"/>
  </fieldset>
</form>
