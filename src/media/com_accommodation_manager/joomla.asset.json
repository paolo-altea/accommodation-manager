{
    "$schema": "https://developer.joomla.org/schemas/json-schema/web_assets.json",
    "name": "com_accommodation_manager",
    "version": "3.3.0",
    "license": "GNU General Public License versione 2 o successiva; vedi LICENSE.txt",
    "assets": [
        {
            "name": "com_accommodation_manager.admin",
            "type": "style",
            "uri": "com_accommodation_manager/admin.css"
        },
        {
            "name": "com_accommodation_manager.admin",
            "type": "script",
            "uri": "com_accommodation_manager/admin.js",
            "attributes": {
                "defer": true
            }
        },
        {
            "name": "com_accommodation_manager.admin-rates",
            "type": "style",
            "uri": "com_accommodation_manager/admin-rates.css"
        },
        {
            "name": "com_accommodation_manager.list",
            "type": "style",
            "uri": "com_accommodation_manager/list.css"
        },
        {
            "name": "com_accommodation_manager.swiper-lib",
            "type": "style",
            "uri": "https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
        },
        {
            "name": "com_accommodation_manager.swiper-lib",
            "type": "script",
            "uri": "https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"
        },
        {
            "name": "com_accommodation_manager.categories-slider",
            "type": "style",
            "uri": "com_accommodation_manager/categories-slider.css",
            "dependencies": [
                "com_accommodation_manager.swiper-lib"
            ]
        },
        {
            "name": "com_accommodation_manager.categories-slider",
            "type": "script",
            "uri": "com_accommodation_manager/categories-slider.js",
            "dependencies": [
                "com_accommodation_manager.swiper-lib"
            ],
            "attributes": {
                "defer": true
            }
        },
        {
            "name": "com_accommodation_manager.gallery-slider",
            "type": "style",
            "uri": "com_accommodation_manager/gallery-slider.css",
            "dependencies": [
                "com_accommodation_manager.swiper-lib"
            ]
        },
        {
            "name": "com_accommodation_manager.gallery-slider",
            "type": "script",
            "uri": "com_accommodation_manager/gallery-slider.js",
            "dependencies": [
                "com_accommodation_manager.swiper-lib"
            ],
            "attributes": {
                "defer": true
            }
        },
        {
            "name": "com_accommodation_manager.category-filter",
            "type": "script",
            "uri": "com_accommodation_manager/category-filter.js",
            "attributes": {
                "defer": true
            }
        },
        {
            "name": "com_accommodation_manager.rates-grid",
            "type": "style",
            "uri": "com_accommodation_manager/rates-grid.css"
        },
        {
            "name": "com_accommodation_manager.rates-grid",
            "type": "script",
            "uri": "com_accommodation_manager/rates-grid.js",
            "attributes": {
                "defer": true
            }
        }
    ]
}